#Write a program to Check strong number
n = int(input("ente the number = "))
temp = n
sum = 0
while (n>0):
    digit = n % 10
    fact = 1
   # print("Digits:" , digit)
    for i in range(1 , digit +1):
        fact = fact*i
   # print("Factorial" , fact)
    sum = sum + fact
  #  print("sum" , sum)
    n = n//10
if sum == temp:
        print(temp , "is strong number")
else:
    print(temp , "is not strong number")
