# que = Write a program to Recursive factorial.
def fact(n): #define function
    # base condition
    if (n == 1):
        return n 
    return n * fact(n-1)

num = int(input("Enter a number = "))

if num < 0:
    print("Factorial is not defined for negative numbers")
else:
    print("Factorial =", fact(num))
